#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Commit message format validation
commit_msg_file=$1
commit_msg=$(cat "$commit_msg_file")

# Regex for conventional commits: type(scope?): description
# Allowed types: feat, fix, docs, style, refactor, test, chore, perf, ci, build, revert
commit_regex='^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\(.+\))?: .{1,}'

if ! echo "$commit_msg" | grep -iqE "$commit_regex"; then
    echo "❌ Invalid commit message format!"
    echo ""
    echo "Commit message must follow Conventional Commits format:"
    echo "  <type>(optional scope): <description>"
    echo ""
    echo "Types: feat, fix, docs, style, refactor, test, chore, perf, ci, build, revert"
    echo ""
    echo "Examples:"
    echo "  feat: add user authentication"
    echo "  fix(api): resolve CORS issue"
    echo "  docs: update README"
    echo ""
    exit 1
fi

